# RummikubSolve — environment variable reference
# Copy this file to .env and fill in real values before running locally.
# Never commit .env — it is listed in .gitignore.

# ── Backend ──────────────────────────────────────────────────────────────────

# Sentry DSN for error and performance monitoring.
# Leave empty (or omit) to run without Sentry — the SDK is a no-op when unset.
# Obtain your DSN from https://sentry.io → Project Settings → Client Keys.
SENTRY_DSN=

# Deployment environment — controls log format and the Sentry "environment" tag.
# "development" → colored console logs
# "production"  → JSON logs (one object per line, suitable for log aggregators)
ENVIRONMENT=development

# Allowed frontend origin for CORS.
# Use the default "*" to permit all origins during local development.
# In production, set to your exact frontend URL (no trailing slash):
#   ALLOWED_ORIGIN=https://rummikub.example.com
ALLOWED_ORIGIN=*

# ── Frontend ──────────────────────────────────────────────────────────────────

# Base URL of the backend API, exposed to the browser bundle at build time.
# Must be reachable from the user's browser (not just the Docker network).
# In production, set to the public backend URL:
#   NEXT_PUBLIC_API_URL=https://api.rummikub.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000
